pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                bat '''
                    node -v
                    npm -v

                    npm ci

                    npx playwright install
                '''
            }
        }

        stage('Compile TypeScript') {
            steps {
                bat '''
                    npx tsc
                '''
            }
        }

        stage('Run Playwright Tests') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'SUCCESS') {
                    bat '''
                        npx playwright test
                    '''
                }
            }
        }
    }

    post {
        always {
            script {

                // Create temp directory if it doesn't exist
                bat '''
                    if not exist "C:\\ProgramData\\Jenkins\\temp" (
                        mkdir "C:\\ProgramData\\Jenkins\\temp"
                    )
                '''

                // Publish Allure report only if results exist
                if (fileExists('allure-results')) {
                    allure(
                        commandline: 'allure',   // Must match the name in Manage Jenkins > Tools
                        includeProperties: false,
                        jdk: '',
                        results: [[path: 'allure-results']]
                    )
                } else {
                    echo 'allure-results folder not found. Skipping Allure report generation.'
                }
            }
        }
    }
}
